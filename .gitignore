# ===================================
# Terraform
# ===================================

# Local .terraform directories (na dowolnej głębokości)
**/.terraform/

# .tfstate files (na dowolnej głębokości)
**/*.tfstate
**/*.tfstate.*
**/*.tfstate.backup
**/*.tfstate.lock.info

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (they may contain sensitive data)
**/*.tfvars
**/*.tfvars.json
**/*.auto.tfvars
**/*.auto.tfvars.json

# Override files
**/override.tf
**/override.tf.json
**_override.tf
**_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# ===================================
# Test files (pliki stanu w testach)
# ===================================

# Ignoruj pliki stanu w katalogu test
test/**/*.tfstate
test/**/*.tfstate.*
test/**/.terraform/
test/**/.terraform.lock.hcl

# ===================================
# Git
# ===================================

# Ignoruj pliki git (ale nie sam katalog .git)
.git/COMMIT_EDITMSG
.git/ORIG_HEAD
.git/index
.git/logs/
.git/objects/

# ===================================
# IDE
# ===================================

# Visual Studio Code
.vscode/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# IntelliJ IDEA / JetBrains
.idea/
*.iml
*.ipr
*.iws
out/

# Vim
*.swp
*.swo
*~
.~*

# ===================================
# OS generated files
# ===================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.dll

# Linux
*~
.directory

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ===================================
# Environment / Secrets
# ===================================

.env
.env.*
*.key
*.pem
*.cert
*.p12

# ===================================
# Logs
# ===================================

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ===================================
# Temporary files
# ===================================

*.tmp
*.temp
*.bak
*.swp
*.swo

# ===================================
# Project specific
# ===================================

# Ignoruj pliki stanu w modułach (jeśli przypadkiem się pojawią)
modules/**/terraform.tfstate
modules/**/terraform.tfstate.*

# Ignoruj pliki lock (powinny być commitowane, ale jeśli nie chcesz)
# modules/**/.terraform.lock.hcl  # odkomentuj jeśli nie chcesz commitować lock file

# Ignoruj katalog data (jeśli zawiera dane tymczasowe)
data/

# Ignoruj katalog staging jeśli jest pusty
environments/staging/